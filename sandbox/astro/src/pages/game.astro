---
import Base from '../layouts/Base.astro';
import ProPlayersGame from '../components/ProPlayersGame.svelte';
---
<Base
  title="Valorandle — Adivinhe o Pro Player de VALORANT"
  description="Adivinhe o pro player de VALORANT no Valorandle. Até 8 tentativas por round, 5 rounds por daily."
  lang="pt-BR"
  path="/game"
  noindex={true}
>
  <script is:inline src="/js/players.js"></script>
  <script is:inline src="/js/game-logic.js"></script>
  <script is:inline src="/js/api.js"></script>

  <ProPlayersGame client:load />

  <script is:inline>
  (function () {
    "use strict";

    const P      = new URLSearchParams(window.location.search);
    const MODE   = P.get("mode") === "free" ? "free" : "daily";
    const LEAGUE = P.get("league") || "all";

    const ENABLED_LEAGUES = ["americas"];
    if (!ENABLED_LEAGUES.includes(LEAGUE)) {
      window.location.replace("/league-select?mode=" + MODE);
    }

    const LEAGUE_CONFIG = {
      americas:{ label:"Americas", color:"#FF5400" },
      emea:    { label:"EMEA",     color:"#C4FF00" },
      pacific: { label:"Pacific",  color:"#00DCFF" },
      china:   { label:"China",    color:"#FF1675" },
      all:     { label:"All",      color:"#E5C96A" }
    };

    let ACTIVE;
    let lang = loadLang();
    let t    = I18N[lang];

    const DAILY_KEY_PREFIX = `valorandle_daily_${LEAGUE}_`;

    function loadLeagueDailyState() {
      try {
        const raw = localStorage.getItem(DAILY_KEY_PREFIX + getDailyDateKey());
        return raw ? JSON.parse(raw) : null;
      } catch { return null; }
    }
    function saveLeagueDailyState(s) {
      try {
        localStorage.setItem(DAILY_KEY_PREFIX + getDailyDateKey(), JSON.stringify(s));
      } catch {}
    }

    let state = {
      mode:MODE, targets:[], currentRound:0,
      guesses:[], roundResults:[], finished:false, dailyDone:false
    };

    let acHighlight = -1, acResults = [];
    let FLIP_PENDING = false;

    let hardMode = localStorage.getItem("valorandle_hard") === "1";
    let soundOn  = localStorage.getItem("valorandle_sound") !== "0";

    function toggleHard() {
      hardMode = !hardMode;
      localStorage.setItem("valorandle_hard", hardMode ? "1" : "0");
      document.getElementById("hard-btn").classList.toggle("active", hardMode);
    }
    function toggleSound() {
      soundOn = !soundOn;
      localStorage.setItem("valorandle_sound", soundOn ? "1" : "0");
      document.getElementById("sound-btn").classList.toggle("active", soundOn);
    }

    let audioCtx = null;
    function getCtx() {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      return audioCtx;
    }
    function playTone(freq, dur, vol=0.07, type="sine", startDelay=0) {
      if (!soundOn) return;
      try {
        const ctx  = getCtx();
        const osc  = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = type; osc.frequency.value = freq;
        gain.gain.setValueAtTime(vol, ctx.currentTime + startDelay);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + startDelay + dur);
        osc.connect(gain); gain.connect(ctx.destination);
        osc.start(ctx.currentTime + startDelay);
        osc.stop(ctx.currentTime + startDelay + dur + 0.05);
      } catch(e) {}
    }
    function playSound(type) {
      if (!soundOn) return;
      if (type === "wrong") {
        playTone(200, 0.22, 0.06, "triangle");
      } else if (type === "correct") {
        playTone(523, 0.15, 0.08); playTone(659, 0.15, 0.08, "sine", 0.12); playTone(784, 0.25, 0.08, "sine", 0.24);
      } else if (type === "flip") {
        playTone(480 + Math.random()*80, 0.07, 0.035, "sine");
      } else if (type === "daily_win") {
        [523,659,784,1046].forEach((f,i) => playTone(f, 0.2, 0.07, "sine", i*0.1));
      }
    }

    function flagHtml(code) {
      if (!code) return '<span class="fi fi-un"></span>';
      return `<span class="fi fi-${code.toLowerCase()}" style="border-radius:2px"></span>`;
    }

    function initGame() {
      applyLang();
      applyLeagueTag();
      updateStreakChip();
      setupHardSound();

      if (MODE === "daily") {
        const saved = loadDailyStateFull();
        if (saved && saved.targets.length > 0) {
          state = { ...state, ...saved };
          if (state.dailyDone) { showDailyComplete(); renderRoundProgress(); return; }
        } else {
          state.targets = getDailyPlayers(ACTIVE);
          state.roundResults=[]; state.currentRound=0; state.guesses=[]; state.finished=false;
        }
        renderRoundProgress();
      } else {
        state.targets=[getRandomPlayer(ACTIVE)]; state.currentRound=0; state.guesses=[]; state.finished=false;
      }

      renderRound();
      setupInput();
      setupGlobalTooltip();
    }

    function applyLeagueTag() {
      const cfg = LEAGUE_CONFIG[LEAGUE];
      if (!cfg) return;
      const el = document.getElementById("league-tag");
      el.style.display = "inline-block";
      el.style.color = cfg.color;
      el.style.border = `1px solid ${cfg.color}44`;
      el.textContent = cfg.label;
    }

    function applyLang() {
      t = I18N[lang];
      document.documentElement.lang = lang;
      document.getElementById("hdr-name").textContent    = t.attribs.name;
      document.getElementById("hdr-country").textContent = t.attribs.country;
      document.getElementById("hdr-team").textContent    = t.attribs.team;
      document.getElementById("hdr-age").textContent     = t.attribs.age;
      document.getElementById("hdr-role").textContent    = t.attribs.role;
      document.getElementById("hdr-titles").textContent  = t.attribs.titles;
      document.getElementById("hdr-years").textContent   = t.attribs.yearsActive;
      document.getElementById("back-btn").textContent    = "← " + t.backLobby;
      document.getElementById("guess-input").placeholder = t.guessPlaceholder;
      document.getElementById("mode-tag").textContent    = MODE === "daily" ? "Daily Mode" : "Free Mode";
      const gfLiq = document.getElementById("gf-liq");
      if (gfLiq) gfLiq.innerHTML = lang === "pt-BR"
        ? 'Dados dos jogadores: <a href="https://liquipedia.net/valorant" target="_blank" rel="noopener">Liquipedia</a> (<a href="https://liquipedia.net/commons/Liquipedia:Copyrights" target="_blank" rel="noopener">CC BY-SA</a>)'
        : 'Player data: <a href="https://liquipedia.net/valorant" target="_blank" rel="noopener">Liquipedia</a> (<a href="https://liquipedia.net/commons/Liquipedia:Copyrights" target="_blank" rel="noopener">CC BY-SA</a>)';
    }

    function setupHardSound() {
      const hBtn = document.getElementById("hard-btn");
      const sBtn = document.getElementById("sound-btn");
      hBtn.classList.toggle("active", hardMode);
      sBtn.classList.toggle("active", soundOn);
      hBtn.addEventListener("click", toggleHard);
      sBtn.addEventListener("click", toggleSound);
    }

    function updateStreakChip() {
      const s = loadStats();
      document.getElementById("streak-num").textContent = s.streak || 0;
    }

    function renderRound() {
      state.guesses = state.guesses || []; state.finished = state.finished || false;
      document.getElementById("round-label").textContent = MODE === "daily"
        ? t.round(state.currentRound+1, DAILY_ROUNDS) : "Free Mode";
      updateAttemptsLabel();
      renderGrid();
      document.getElementById("guess-input").disabled = state.finished;
      document.getElementById("guess-btn").disabled   = state.finished;
    }

    function updateAttemptsLabel() {
      const n = state.guesses.length;
      const el = document.getElementById("attempts-label");
      el.textContent = t.attempts(n, MAX_GUESSES);
      el.classList.toggle("low", n >= MAX_GUESSES - 2);
    }

    function renderRoundProgress() {
      const c = document.getElementById("round-progress");
      if (MODE !== "daily") { c.style.display = "none"; return; }
      c.style.display = "flex"; c.innerHTML = "";
      for (let i = 0; i < DAILY_ROUNDS; i++) {
        const pip = document.createElement("div");
        pip.className = "round-pip";
        if (i < state.currentRound) pip.classList.add((state.roundResults[i]&&state.roundResults[i].won)?"done":"failed");
        else if (i === state.currentRound) pip.classList.add("active");
        c.appendChild(pip);
      }
    }

    function renderGrid() {
      const grid = document.getElementById("guess-grid");
      grid.innerHTML = "";
      state.guesses.forEach(g => grid.appendChild(createGuessRow(g, false)));
      for (let i=0; i < MAX_GUESSES - state.guesses.length; i++) grid.appendChild(createEmptyRow());
    }

    function cellValue(fb, player) {
      if (fb.attr === "role") return translateRole(fb.value, t.roles);
      if (fb.attr === "yearsActive") return `${fb.value} ${t.years}`;
      if (fb.attr === "titles" && fb.value === "Nenhum") return t.noTitles;
      if (fb.attr === "country") {
        const countryName = lang === "en" ? (COUNTRY_EN[fb.value] || fb.value) : fb.value;
        return `<span class="cell-flag">${flagHtml(player.countryCode)} <span>${countryName}</span></span>`;
      }
      return String(fb.value);
    }

    function createGuessRow(guessData, animate) {
      const {player, feedback} = guessData;
      const target = state.targets[state.currentRound];
      const isWin  = player.id === target.id;
      const row    = document.createElement("div");
      row.className = "guess-row";

      const nc = document.createElement("div");
      nc.className = "guess-cell" + (isWin ? " correct" : "");
      nc.innerHTML = `<span class="cell-value">${player.displayName}</span><span style="font-size:.62rem;color:var(--text-dim);font-family:var(--font-mono)">${player.league}</span>`;
      nc.dataset.tip = buildNameTip(player);
      row.appendChild(nc);

      feedback.forEach((fb, i) => {
        const cell = document.createElement("div");
        cell.className = animate ? "guess-cell" : `guess-cell ${fb.status}`;
        const hint = (!hardMode && fb.hint) ? fb.hint : "";
        cell.innerHTML = `<span class="cell-value">${cellValue(fb, player)}</span>${hint ? `<span class="cell-hint">${hint}</span>` : ""}`;
        cell.dataset.tip = buildFeedbackTip(fb, player, target);
        row.appendChild(cell);

        if (animate) {
          const delay = (i+1) * 115;
          setTimeout(() => {
            cell.classList.add("flip-out");
            setTimeout(() => {
              cell.classList.remove("flip-out");
              cell.classList.add(fb.status, "flip-in");
              playSound("flip");
              setTimeout(() => cell.classList.remove("flip-in"), 180);
            }, 170);
          }, delay);
        }
      });

      if (animate) {
        nc.classList.remove("correct");
        setTimeout(() => {
          nc.classList.add("flip-out");
          setTimeout(() => {
            nc.classList.remove("flip-out");
            if (isWin) nc.classList.add("correct");
            nc.classList.add("flip-in");
            setTimeout(() => nc.classList.remove("flip-in"), 180);
          }, 170);
        }, 0);
      }
      return row;
    }

    function createEmptyRow() {
      const row = document.createElement("div");
      row.className = "guess-row guess-row-empty";
      for (let i=0; i<7; i++) {
        const c = document.createElement("div"); c.className = "guess-cell empty"; row.appendChild(c);
      }
      return row;
    }

    function buildNameTip(p) {
      return `<span class="tip-title">${p.displayName}</span>` +
        `<span class="tip-row">${flagHtml(p.countryCode)} ${p.country}</span>` +
        `<span class="tip-row">${p.team} · ${p.league}</span>` +
        `<span class="tip-row">${translateRole(p.role||"", t.roles)} · ${p.age} ${t.years}</span>` +
        `<span class="tip-row">${p.yearsActive} ${t.years} ${lang==="pt-BR"?"ativo":"active"}</span>`;
    }

    function buildFeedbackTip(fb, player, target) {
      const isPT = lang === "pt-BR";
      let h = `<span class="tip-title">${t.attribs[fb.attr]||fb.attr}</span>`;
      const ok  = fb.status === "correct";
      const mid = fb.status === "close";

      if (fb.attr === "country") {
        h += `<span class="tip-row">${flagHtml(player.countryCode)} ${player.country}</span>`;
        h += `<span class="tip-row ${ok?"ok":"bad"}">${ok?(isPT?"Correto!":"Correct!"):(isPT?"Errado":"Wrong")}</span>`;
      } else if (fb.attr === "team") {
        h += `<span class="tip-row">${fb.value}</span>`;
        h += `<span class="tip-row ${ok?"ok":"bad"}">${ok?(isPT?"Correto!":"Correct!"):(isPT?"Errado":"Wrong")}</span>`;
      } else if (fb.attr === "age") {
        const diff = target.age - player.age;
        h += `<span class="tip-row">${fb.value} ${t.years}</span>`;
        if (diff === 0) { h += `<span class="tip-row ok">${isPT?"Correto!":"Correct!"}</span>`; }
        else {
          const dir = diff>0?(isPT?"↑ Alvo é mais velho":"↑ Target is older"):(isPT?"↓ Alvo é mais novo":"↓ Target is younger");
          const cl  = Math.abs(diff) <= 3;
          h += `<span class="tip-row">${dir}</span>`;
          h += `<span class="tip-row ${cl?"mid":"bad"}">${cl?(isPT?"Quase!":"Close!"):(isPT?"Longe!":"Far!")}</span>`;
        }
      } else if (fb.attr === "role") {
        h += `<span class="tip-row">${translateRole(fb.value, t.roles)}</span>`;
        if (ok)       h += `<span class="tip-row ok">${isPT?"Correto!":"Correct!"}</span>`;
        else if (mid) h += `<span class="tip-row mid">${isPT?"Mesmo grupo":"Same group"}</span>`;
        else          h += `<span class="tip-row bad">${isPT?"Grupo diferente":"Different group"}</span>`;
        h += `<span class="tip-note">${isPT?"Baseado nas últimas 5 partidas oficiais":"Based on last 5 official matches"}</span>`;
      } else if (fb.attr === "titles") {
        if (fb.fullList && fb.fullList.length > 0) fb.fullList.forEach(tt => { h += `<span class="tip-row">— ${tt}</span>`; });
        else h += `<span class="tip-row">${t.noTitles}</span>`;
        h += `<span class="tip-row ${ok?"ok":"bad"}">${ok?(isPT?"Correto!":"Correct!"):(isPT?"Diferente":"Different")}</span>`;
      } else if (fb.attr === "yearsActive") {
        const diff = (target.yearsActive||0) - (player.yearsActive||0);
        h += `<span class="tip-row">${fb.value} ${t.years}</span>`;
        if (diff === 0) { h += `<span class="tip-row ok">${isPT?"Correto!":"Correct!"}</span>`; }
        else {
          const dir = diff>0?(isPT?"↑ Alvo tem mais":"↑ Target has more"):(isPT?"↓ Alvo tem menos":"↓ Target has less");
          const cl  = Math.abs(diff) <= 1;
          h += `<span class="tip-row">${dir}</span>`;
          h += `<span class="tip-row ${cl?"mid":"bad"}">${cl?(isPT?"Quase!":"Close!"):(isPT?"Longe!":"Far!")}</span>`;
        }
      }
      return h;
    }

    function setupGlobalTooltip() {
      const tip  = document.getElementById("g-tip");
      const grid = document.getElementById("guess-grid");
      let   cur  = null;

      function show(cell) {
        const data = cell.dataset.tip;
        if (!data) return;
        tip.innerHTML = data;
        tip.style.display = "block";
        tip.classList.remove("tip-above");
        const r = cell.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        tip.style.top  = (r.bottom + 8) + "px";
        tip.style.left = cx + "px";
        tip.style.transform = "translateX(-50%)";
        requestAnimationFrame(() => {
          const tr = tip.getBoundingClientRect();
          if (tr.bottom > window.innerHeight - 10) {
            tip.style.top = (r.top - tr.height - 8) + "px";
            tip.classList.add("tip-above");
          }
          const tr2 = tip.getBoundingClientRect();
          if (tr2.right > window.innerWidth - 8)  tip.style.left = (cx - (tr2.right - window.innerWidth + 8)) + "px";
          if (tr2.left  < 8)                       tip.style.left = (cx + (8 - tr2.left)) + "px";
        });
        cur = cell;
      }

      function hide() {
        tip.style.display = "none";
        tip.classList.remove("tip-above");
        cur = null;
      }

      grid.addEventListener("mouseover", e => {
        const cell = e.target.closest(".guess-cell:not(.empty)");
        if (cell && cell !== cur) show(cell);
        else if (!cell) hide();
      });
      grid.addEventListener("mouseleave", hide);
      document.querySelector(".grid-scroll-wrapper").addEventListener("scroll", hide);
    }

    function setupInput() {
      const input = document.getElementById("guess-input");
      const btn   = document.getElementById("guess-btn");

      input.addEventListener("input", () => {
        const q = input.value.trim().toLowerCase();
        if (!q) { hideAC(); return; }
        const used = state.guesses.map(g => g.player.id);
        acResults = ACTIVE.filter(p =>
          (p.name.toLowerCase().includes(q) || p.displayName.toLowerCase().includes(q)) && !used.includes(p.id)
        ).slice(0, 8);
        renderAC(acResults);
      });

      input.addEventListener("keydown", e => {
        if      (e.key==="ArrowDown"){ e.preventDefault(); acHighlight=Math.min(acHighlight+1,acResults.length-1); hlAC(); }
        else if (e.key==="ArrowUp")  { e.preventDefault(); acHighlight=Math.max(acHighlight-1,-1); hlAC(); }
        else if (e.key==="Enter")    { e.preventDefault(); acHighlight>=0&&acResults[acHighlight]?selectP(acResults[acHighlight]):submitGuess(); }
        else if (e.key==="Escape")   hideAC();
      });

      btn.addEventListener("click", submitGuess);
      document.addEventListener("click", e => { if (!e.target.closest(".input-section")) hideAC(); });
    }

    function renderAC(players) {
      const list = document.getElementById("autocomplete-list");
      if (!players.length) { list.style.display="none"; return; }
      list.style.display="block"; acHighlight=-1; list.innerHTML="";
      players.forEach(p => {
        const item = document.createElement("div");
        item.className = "autocomplete-item";
        item.innerHTML = `<span class="ac-flag">${flagHtml(p.countryCode)}</span><span><span class="ac-name">${p.displayName}</span><span class="ac-team"> · ${p.team}</span></span><span class="ac-league">${p.league}</span>`;
        item.addEventListener("mousedown", e => { e.preventDefault(); selectP(p); });
        list.appendChild(item);
      });
    }

    function hlAC() {
      document.querySelectorAll(".autocomplete-item").forEach((el,i)=>el.classList.toggle("highlighted",i===acHighlight));
      if (acHighlight>=0&&acResults[acHighlight]) document.getElementById("guess-input").value=acResults[acHighlight].displayName;
    }

    function selectP(player) { document.getElementById("guess-input").value=player.displayName; hideAC(); submitGuessForPlayer(player); }
    function hideAC() { document.getElementById("autocomplete-list").style.display="none"; acResults=[]; acHighlight=-1; }

    function submitGuess() {
      if (FLIP_PENDING) return;
      const q = document.getElementById("guess-input").value.trim().toLowerCase();
      if (!q) return;
      const player = ACTIVE.find(p => p.name.toLowerCase()===q || p.displayName.toLowerCase()===q);
      if (!player) { showError(t.notFound); return; }
      submitGuessForPlayer(player);
    }

    function submitGuessForPlayer(player) {
      if (FLIP_PENDING || state.finished) return;
      clearError();
      if (state.guesses.some(g => g.player.id===player.id)) { showError(t.alreadyGuessed); return; }

      const target   = state.targets[state.currentRound];
      const feedback = compareGuess(player, target);
      state.guesses.push({ player, feedback });
      document.getElementById("guess-input").value = "";
      hideAC();

      const grid    = document.getElementById("guess-grid");
      const empties = grid.querySelectorAll(".guess-row-empty");
      if (empties.length) empties[empties.length-1].remove();
      const newRow     = createGuessRow({player, feedback}, true);
      const firstEmpty = grid.querySelector(".guess-row-empty");
      if (firstEmpty) grid.insertBefore(newRow, firstEmpty);
      else            grid.appendChild(newRow);
      updateAttemptsLabel();

      const FLIP_MS = 7 * 115 + 170 + 180;
      const won     = player.id === target.id;
      const outOfG  = state.guesses.length >= MAX_GUESSES;

      if (won || outOfG) {
        FLIP_PENDING = true;
        document.getElementById("guess-btn").disabled   = true;
        document.getElementById("guess-input").disabled = true;
        setTimeout(() => {
          FLIP_PENDING = false;
          endRound(won, target);
          playSound(won ? "correct" : "wrong");
        }, FLIP_MS + 100);
      }

      if (MODE === "daily") saveLeagueDailyState(getSerializableState());
    }

    function endRound(won, target) {
      state.finished = true;
      document.getElementById("guess-input").disabled = true;
      document.getElementById("guess-btn").disabled   = true;
      if (MODE==="daily") { state.roundResults.push({won, guesses:state.guesses}); renderRoundProgress(); }
      if (MODE==="free")  updateStats(won, true);
      showRoundResult(won, target);
      if (MODE==="daily") saveLeagueDailyState(getSerializableState());
    }

    function showRoundResult(won, target) {
      const panel = document.getElementById("result-banner");
      panel.style.display = "block";
      panel.className     = "result-panel " + (won?"won":"lost");

      const hardBadge = document.getElementById("result-hard-badge");
      if (hardBadge) hardBadge.remove();
      if (hardMode) {
        const badge = document.createElement("span");
        badge.id = "result-hard-badge";
        badge.textContent = "HARD";
        badge.style.cssText = "display:inline-block;margin-left:0.5rem;padding:0.15rem 0.45rem;background:#FF4655;color:#fff;font-size:0.6rem;font-weight:700;letter-spacing:0.03em;border-radius:3px;vertical-align:middle;";
        document.getElementById("banner-title").insertAdjacentElement("afterend", badge);
      }

      document.getElementById("banner-title").textContent = won
        ? (lang==="pt-BR"?"Correto!":"Correct!")
        : (lang==="pt-BR"?`Era: ${target.displayName}`:`It was: ${target.displayName}`);

      document.getElementById("result-flag").innerHTML = flagHtml(target.countryCode);
      document.getElementById("result-name").textContent = target.displayName;
      document.getElementById("result-sub").textContent  = `${target.team} · ${translateRole(target.role||"", t.roles)} · ${target.age} ${t.years} · ${target.yearsActive} ${t.years} ${lang==="pt-BR"?"ativo":"active"}`;

      const graphDiv = document.getElementById("result-graph");
      graphDiv.style.display = "block";
      document.getElementById("result-graph-label").textContent = lang==="pt-BR"
        ? `${state.guesses.length} de ${MAX_GUESSES} tentativas`
        : `${state.guesses.length} of ${MAX_GUESSES} attempts`;
      const track = document.getElementById("attempt-track");
      track.innerHTML = "";
      for (let i=1; i<=MAX_GUESSES; i++) {
        const dot = document.createElement("div");
        dot.className = "attempt-dot"; dot.textContent = i;
        if (i < state.guesses.length)       dot.classList.add("wrong");
        else if (i === state.guesses.length) dot.classList.add(won?"win":"wrong");
        track.appendChild(dot);
      }

      const repDiv = document.getElementById("result-replay");
      repDiv.style.display = "block";
      document.getElementById("replay-label").textContent = lang==="pt-BR"?"Último chute":"Last guess";
      const cells = document.getElementById("replay-cells");
      cells.innerHTML = "";
      const last = state.guesses[state.guesses.length-1];
      if (last) last.feedback.forEach(fb => {
        const sq = document.createElement("div");
        sq.className = `replay-cell ${fb.status}`; sq.title = fb.attr;
        cells.appendChild(sq);
      });

      const acts = document.getElementById("banner-actions");
      acts.innerHTML = "";
      if (MODE==="daily" && state.currentRound < DAILY_ROUNDS-1)
        acts.appendChild(makeBtn(lang==="pt-BR"?"Próximo →":"Next →","btn-action btn-next",advanceRound));
      if (MODE==="free")
        acts.appendChild(makeBtn(t.playAgain,"btn-action btn-next",startFreeRound));
      if (MODE==="daily" && state.currentRound===DAILY_ROUNDS-1)
        setTimeout(completeDailyAndFinish, 600);

      acts.appendChild(makeBtn(t.shareBtn,"btn-action btn-share",shareDaily));
      acts.appendChild(makeBtn(lang==="pt-BR"?"Img":"Img","btn-action btn-img",shareImage));
      acts.appendChild(makeBtn(t.backLobby,"btn-action btn-lobby",()=>{ window.location.href="/"; }));
    }

    function makeBtn(label, cls, fn) {
      const b = document.createElement("button");
      b.className=cls; b.textContent=label; b.addEventListener("click",fn); return b;
    }

    function advanceRound() {
      state.currentRound++; state.guesses=[]; state.finished=false;
      document.getElementById("result-banner").style.display="none";
      document.getElementById("guess-input").disabled=false;
      document.getElementById("guess-btn").disabled=false;
      renderRoundProgress(); renderRound();
      saveLeagueDailyState(getSerializableState());
    }

    function completeDailyAndFinish() {
      state.dailyDone = true;
      const wins = state.roundResults.filter(r=>r.won).length;
      updateStats(wins===DAILY_ROUNDS, true);
      saveLeagueDailyState(getSerializableState());
      updateStreakChip();
      showDailyComplete();
      if (wins === DAILY_ROUNDS) launchConfetti();
      else if (wins > 0) playSound("correct");
      playSound("daily_win");
    }

    function showDailyComplete() {
      document.getElementById("daily-complete").style.display    = "block";
      document.getElementById("result-banner").style.display     = "none";
      document.querySelector(".input-section").style.display     = "none";
      document.querySelector(".grid-scroll-wrapper").style.display = "none";
      document.querySelector(".round-info").style.display        = "none";
      const wins = (state.roundResults||[]).filter(r=>r.won).length;
      document.getElementById("dc-title").textContent = wins===DAILY_ROUNDS
        ? (lang==="pt-BR"?"Daily Completo!":"Daily Complete!")
        : (lang==="pt-BR"?"Daily Encerrado":"Daily Ended");
      document.getElementById("dc-sub").textContent = lang==="pt-BR"
        ? `Você acertou ${wins} de ${DAILY_ROUNDS} rounds.`
        : `You got ${wins} out of ${DAILY_ROUNDS} rounds.`;
      const acts = document.getElementById("dc-actions");
      acts.innerHTML = "";
      acts.appendChild(makeBtn(t.shareBtn,"btn-action btn-next",shareDaily));
      acts.appendChild(makeBtn(lang==="pt-BR"?"Salvar Img":"Save Img","btn-action btn-share",shareImage));
      acts.appendChild(makeBtn(t.backLobby,"btn-action btn-lobby",()=>{ window.location.href="/"; }));
    }

    function startFreeRound() {
      const used = state.targets.map(p=>p.id);
      state.targets=[getRandomPlayer(ACTIVE,used)||getRandomPlayer(ACTIVE)];
      state.guesses=[]; state.finished=false;
      document.getElementById("result-banner").style.display="none";
      document.getElementById("guess-input").disabled=false;
      document.getElementById("guess-btn").disabled=false;
      renderRound();
    }

    function updateStats(won, countPlay) {
      const s = loadStats();
      if (countPlay) s.played++;
      if (won) { s.wins++; s.streak++; s.maxStreak=Math.max(s.streak,s.maxStreak); }
      else s.streak=0;
      saveStats(s);
    }

    function shareDaily() {
      const text = generateShareText(getDailyDateKey(), state.roundResults, lang);
      if (navigator.clipboard)
        navigator.clipboard.writeText(text)
          .then(()=>showToast(lang==="pt-BR"?"Copiado!":"Copied!"))
          .catch(()=>fallbackCopy(text));
      else fallbackCopy(text);
    }
    function fallbackCopy(text) {
      const ta=document.createElement("textarea"); ta.value=text;
      document.body.appendChild(ta); ta.select(); document.execCommand("copy");
      document.body.removeChild(ta); showToast(lang==="pt-BR"?"Copiado!":"Copied!");
    }

    function shareImage() {
      const guesses = state.guesses;
      const DPR = Math.min(window.devicePixelRatio||1, 2);
      const COLS=6, CELL=22, GAP=3, PAD=20;
      const ROW_H=CELL+GAP;
      const W=PAD*2+(COLS*CELL+(COLS-1)*GAP);
      const H=PAD*2+64+guesses.length*ROW_H+20;
      const canvas=document.createElement("canvas");
      canvas.width=W*DPR; canvas.height=H*DPR;
      const ctx=canvas.getContext("2d");
      ctx.scale(DPR,DPR);
      ctx.fillStyle="#08090d"; ctx.fillRect(0,0,W,H);
      ctx.fillStyle="#1c1f2e";
      for (let gx=0;gx<W;gx+=14) for (let gy=0;gy<H;gy+=14) ctx.fillRect(gx,gy,1,1);
      ctx.font="bold 18px 'Russo One',sans-serif"; ctx.fillStyle="#eeeef5";
      ctx.fillText("VALOR",PAD,PAD+18); ctx.fillStyle="#FF4655";
      ctx.fillText("ANDLE",PAD+ctx.measureText("VALOR").width,PAD+18);
      ctx.font="10px 'Outfit',sans-serif"; ctx.fillStyle="#50536a";
      ctx.fillText(`${getDailyDateKey()} · ${(LEAGUE_CONFIG[LEAGUE]||{label:"All"}).label}`,PAD,PAD+36);
      ctx.strokeStyle="#1c1f2e"; ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(PAD,PAD+46); ctx.lineTo(W-PAD,PAD+46); ctx.stroke();
      const colors={correct:{bg:"#0d1f14",bd:"#34d47e"},close:{bg:"#1a1408",bd:"#f0b429"},wrong:{bg:"#160508",bd:"#FF4655"}};
      guesses.forEach((g,gi) => {
        const gy=PAD+58+gi*ROW_H;
        g.feedback.forEach((fb,fi) => {
          const gx=PAD+fi*(CELL+GAP);
          const c=colors[fb.status]||colors.wrong;
          ctx.fillStyle=c.bg; ctx.strokeStyle=c.bd; ctx.lineWidth=1;
          ctx.beginPath(); ctx.roundRect(gx,gy,CELL,CELL,2); ctx.fill(); ctx.stroke();
        });
      });
      ctx.font="9px 'Outfit',sans-serif"; ctx.fillStyle="#252838";
      ctx.fillText("valorandle.com",PAD,H-7);
      canvas.toBlob(blob => {
        if (navigator.share&&navigator.canShare&&navigator.canShare({files:[new File([blob],"result.png",{type:"image/png"})]})) {
          navigator.share({files:[new File([blob],"valorandle.png",{type:"image/png"})],title:"Valorandle"}).catch(()=>downloadBlob(blob));
        } else { downloadBlob(blob); }
      },"image/png");
    }

    function downloadBlob(blob) {
      const url=URL.createObjectURL(blob);
      const a=document.createElement("a");
      a.href=url; a.download=`valorandle-${getDailyDateKey()}.png`;
      a.click(); URL.revokeObjectURL(url);
      showToast(lang==="pt-BR"?"Imagem salva!":"Image saved!");
    }

    function launchConfetti() {
      const canvas=document.createElement("canvas");
      canvas.style.cssText="position:fixed;inset:0;z-index:8999;pointer-events:none;width:100%;height:100%";
      canvas.width=window.innerWidth; canvas.height=window.innerHeight;
      document.body.appendChild(canvas);
      const ctx=canvas.getContext("2d");
      const colors=["#FF4655","#ffffff","#FF8C94","#ffccd1","#cc2233","#ff6670","#FF5400","#C4FF00"];
      const pieces=Array.from({length:110},()=>({
        x:Math.random()*canvas.width, y:-10-Math.random()*120,
        w:4+Math.random()*9, h:3+Math.random()*5,
        r:Math.random()*Math.PI*2, rv:(Math.random()-.5)*.18,
        vx:(Math.random()-.5)*2.2, vy:1.8+Math.random()*3,
        g:0.04+Math.random()*.04,
        c:colors[Math.floor(Math.random()*colors.length)]
      }));
      let raf;
      (function draw() {
        ctx.clearRect(0,0,canvas.width,canvas.height);
        let alive=false;
        pieces.forEach(p=>{
          p.x+=p.vx; p.y+=p.vy; p.vy+=p.g; p.r+=p.rv;
          if (p.y<canvas.height+20) alive=true;
          ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.r);
          ctx.fillStyle=p.c; ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
          ctx.restore();
        });
        if (alive) raf=requestAnimationFrame(draw); else canvas.remove();
      })();
      setTimeout(()=>{cancelAnimationFrame(raf);canvas.remove();},5500);
    }

    function showToast(msg) {
      const el=document.getElementById("toast");
      el.textContent=msg; el.classList.add("show");
      setTimeout(()=>el.classList.remove("show"),2200);
    }
    function showError(msg) { document.getElementById("input-error").textContent=msg; }
    function clearError()   { document.getElementById("input-error").textContent=""; }

    function getSerializableState() {
      return {
        mode:state.mode, targets:state.targets.map(p=>p.id), currentRound:state.currentRound,
        guesses:state.guesses.map(g=>({playerId:g.player.id,feedback:g.feedback})),
        roundResults:(state.roundResults||[]).map(r=>({won:r.won,guesses:r.guesses.map(g=>({playerId:g.player.id,feedback:g.feedback}))})),
        finished:state.finished, dailyDone:state.dailyDone
      };
    }
    function loadDailyStateFull() {
      const raw=loadLeagueDailyState(); if (!raw) return null;
      const pm=Object.fromEntries(PLAYERS_DB.map(p=>[p.id,p]));
      return {
        mode:raw.mode, targets:(raw.targets||[]).map(id=>pm[id]).filter(Boolean),
        currentRound:raw.currentRound||0,
        guesses:(raw.guesses||[]).map(g=>({player:pm[g.playerId],feedback:g.feedback})).filter(g=>g.player),
        roundResults:(raw.roundResults||[]).map(r=>({won:r.won,guesses:(r.guesses||[]).map(g=>({player:pm[g.playerId],feedback:g.feedback})).filter(g=>g.player)})),
        finished:raw.finished||false, dailyDone:raw.dailyDone||false
      };
    }

    document.addEventListener("DOMContentLoaded", async function () {
      await window.initPlayersDB();
      ACTIVE = LEAGUE === "all" ? PLAYERS_DB : PLAYERS_DB.filter(p => p.leagueId === LEAGUE);
      document.getElementById("loading-overlay").style.display = "none";
      initGame();
    });
  })();
  </script>
</Base>

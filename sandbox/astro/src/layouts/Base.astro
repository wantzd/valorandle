---
import '../styles/global.css';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  canonical: string;
  altHref: string;   // the other language's URL
}

const { lang, canonical, altHref } = Astro.props;
const t = useTranslations(lang);

const ptUrl = lang === 'pt-BR' ? canonical : altHref;
const enUrl = lang === 'en'    ? canonical : altHref;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t('meta.title')}</title>
  <meta name="description" content={t('meta.description')} />
  <meta name="keywords"    content={t('meta.keywords')} />
  <meta name="robots"      content="index, follow" />
  <meta name="author"      content="Valorandle" />

  <!-- Canonical + hreflang — gerado automaticamente a partir do lang prop -->
  <link rel="canonical"  href={canonical} />
  <link rel="alternate"  hreflang="pt-BR"    href={ptUrl} />
  <link rel="alternate"  hreflang="en"       href={enUrl} />
  <link rel="alternate"  hreflang="x-default" href="https://valorandle.com/" />

  <!-- Open Graph -->
  <meta property="og:type"             content="website" />
  <meta property="og:url"              content={canonical} />
  <meta property="og:site_name"        content="Valorandle" />
  <meta property="og:locale"           content={t('og.locale')} />
  <meta property="og:locale:alternate" content={t('og.locale.alt')} />
  <meta property="og:title"            content={t('meta.title')} />
  <meta property="og:description"      content={t('meta.description')} />
  <meta property="og:image"            content="https://valorandle.com/assets/icons/app-icon-512.png" />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={t('meta.title')} />
  <meta name="twitter:description" content={t('meta.description')} />
  <meta name="twitter:image"       content="https://valorandle.com/assets/icons/app-icon-512.png" />

  <meta name="theme-color" content="#FF4655" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg" />
  <link rel="icon" type="image/png" sizes="64x64" href="/assets/icons/favicon-64.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-180.png" />
  <link rel="manifest" href="/manifest.json" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Russo+One&family=Space+Grotesk:wght@300;400;500;600&family=Space+Mono:wght@700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flag-icons@7.2.3/css/flag-icons.min.css" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Valorandle",
    "alternateName": ["Valorant Wordle", "Valdle"],
    "description": t('meta.description'),
    "url": canonical,
    "applicationCategory": "GameApplication",
    "genre": "Puzzle",
    "operatingSystem": "Web",
    "inLanguage": ["pt-BR", "en"],
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "BRL" },
    "image": "https://valorandle.com/assets/icons/app-icon-512.png"
  })} />
</head>
<body>
  <slot />

  <!-- Game logic scripts (vanilla JS, unchanged from original) -->
  <script is:inline src="/js/players.js"></script>
  <script is:inline src="/js/game-logic.js"></script>
</body>
</html>

---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="countdown-wrap">
  <span class="countdown-lbl">{t('countdown.label')}</span>
  <span class="countdown-timer" id="countdown-timer">--:--:--</span>
</div>

<script is:inline>
(function () {
  if (typeof msUntilNextDaily === 'undefined' || typeof formatCountdown === 'undefined') return;
  function tick() {
    const el = document.getElementById('countdown-timer');
    if (el) el.textContent = formatCountdown(msUntilNextDaily());
  }
  tick();
  setInterval(tick, 1000);
})();
</script>

---
interface Props {
  name: string;
  desc: string;
  tag: 'new' | 'beta' | 'soon';
  tagLabel: string;
  href: string;
  icon: string;       // inline SVG string
  disabled?: boolean;
}

const { name, desc, tag, tagLabel, href, icon, disabled = false } = Astro.props;
---

<a class:list={['mode-row', { disabled }]}
   href={disabled ? undefined : href}
   aria-disabled={disabled ? 'true' : undefined}>

  <div class="mode-icon" set:html={icon} />

  <div class="mode-info">
    <div class="mode-name">{name}</div>
    <div class="mode-desc">{desc}</div>
  </div>

  <span class:list={['mode-tag', tag]}>{tagLabel}</span>
  <span class="mode-arrow">→</span>
</a>

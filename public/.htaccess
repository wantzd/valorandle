ErrorDocument 404 /404.html

Options -Indexes

RewriteEngine On

# Redirect old .html URLs to clean Astro routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^league-select\.html$ /league-select [R=301,L]
RewriteRule ^game\.html$          /game          [R=301,L]
RewriteRule ^skins\.html$         /skins         [R=301,L]
RewriteRule ^agents\.html$        /agents        [R=301,L]
RewriteRule ^abilities\.html$     /abilities     [R=301,L]
RewriteRule ^maps\.html$          /maps          [R=301,L]

RewriteRule ^en/league-select\.html$ /en/league-select [R=301,L]
RewriteRule ^en/game\.html$          /en/game          [R=301,L]
RewriteRule ^en/skins\.html$         /en/skins         [R=301,L]
RewriteRule ^en/agents\.html$        /en/agents        [R=301,L]
RewriteRule ^en/abilities\.html$     /en/abilities     [R=301,L]
RewriteRule ^en/maps\.html$          /en/maps          [R=301,L]

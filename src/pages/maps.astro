---
import Base from '../layouts/Base.astro';
import MapsGame from '../components/MapsGame.svelte';

const css = `
:root {
  --font-display:'Russo One', sans-serif; --font-ui:'Outfit', sans-serif; --font-mono:'Outfit', sans-serif;
  --map-blur:14px; --map-scale:2.2;
}
`;
---
<Base
  title="Valorandle — Mapas"
  description="Adivinhe o callout do mapa de VALORANT com base em uma screenshot com zoom progressivo."
  lang="pt-BR"
  path="/maps"
  extraCss={css}
  noindex={true}
>
  <MapsGame client:load />
</Base>

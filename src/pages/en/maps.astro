---
import Base from '../../layouts/Base.astro';
import MapsGame from '../../components/MapsGame.svelte';

const css = `
:root {
  --font-display:'Russo One', sans-serif; --font-ui:'Outfit', sans-serif; --font-mono:'Outfit', sans-serif;
  --map-blur:14px; --map-scale:2.2;
}
`;
---
<Base
  title="Valorandle — Maps"
  description="Guess the VALORANT map callout in Valorandle. Progressively zooming screenshot with hints."
  lang="en"
  path="/maps"
  extraCss={css}
  noindex={true}
>
  <MapsGame client:load />
</Base>

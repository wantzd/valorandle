---
interface Props {
  title: string;
  description: string;
  lang: 'pt-BR' | 'en';
  path: string;
  extraCss?: string;
  noindex?: boolean;
}

const { title, description, lang, path, extraCss, noindex = false } = Astro.props;

const isRoot  = path === '/' || path === '';
const canonical  = `https://valorandle.com${lang === 'en' ? '/en' : ''}${isRoot && lang !== 'en' ? '/' : path}`;
const hreflangPT = isRoot ? 'https://valorandle.com/' : `https://valorandle.com${path}`;
const hreflangEN = isRoot ? 'https://valorandle.com/en'  : `https://valorandle.com/en${path}`;
const ogLocale = lang === 'en' ? 'en_US' : 'pt_BR';
const ogLocaleAlt = lang === 'en' ? 'pt_BR' : 'en_US';

const schemaDescription = lang === 'en'
  ? "Guess VCT pro players, agents, maps and skins in Valorandle. Daily challenges with players from all 4 global leagues. Put your VALORANT knowledge to the test."
  : "Adivinhe pro players do VCT, agentes, mapas e skins de VALORANT. Desafio novo todo dia com jogadores das 4 ligas globais. Prove que você sabe tudo de VALORANT.";

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Valorandle",
  "alternateName": ["Valdle", "Valorandle Quiz"],
  "description": schemaDescription,
  "url": canonical,
  "applicationCategory": "GameApplication",
  "genre": "Puzzle",
  "operatingSystem": "Web",
  "inLanguage": ["pt-BR", "en"],
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "BRL" },
  "image": "https://valorandle.com/assets/icons/og-banner.png"
});
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="valorandle, valdle, valorant quiz, vct pro player, adivinhe jogador valorant, valorant agentes, valorant mapas, valorant skins" />
  {noindex ? <meta name="robots" content="noindex, follow" /> : <meta name="robots" content="index, follow" />}
  <meta name="author" content="Valorandle" />

  <!-- Canonical + hreflang -->
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="pt-BR" href={hreflangPT} />
  <link rel="alternate" hreflang="en" href={hreflangEN} />
  <link rel="alternate" hreflang="x-default" href={hreflangPT} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Valorandle" />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:locale:alternate" content={ogLocaleAlt} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://valorandle.com/assets/icons/og-banner.png" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://valorandle.com/assets/icons/og-banner.png" />

  <meta name="theme-color" content="#FF4655" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg" />
  <link rel="icon" type="image/png" sizes="64x64" href="/assets/icons/favicon-64.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-180.png" />
  <link rel="manifest" href="/manifest.json" />

  <!-- Fonts (non-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Russo+One&family=Epilogue:wght@400;600;700&family=Montserrat:wght@500;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Russo+One&family=Epilogue:wght@400;600;700&family=Montserrat:wght@500;700&display=swap" /></noscript>
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/flag-icons@7.2.3/css/flag-icons.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flag-icons@7.2.3/css/flag-icons.min.css" /></noscript>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={schemaJson} />

  {extraCss && <style is:global set:html={extraCss} />}
  <style is:global>
    :root { --font-ui: 'Epilogue', sans-serif !important; --font-mono: 'Epilogue', sans-serif !important; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
